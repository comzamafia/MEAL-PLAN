# ===========================================
# Wela Meal Plan - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ===========================================
# Database (Railway PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:password@host:port/dbname
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=wela_meal_plan
POSTGRES_HOST=
POSTGRES_PORT=5432

# ===========================================
# Redis (Railway Redis)
# ===========================================
REDIS_URL=redis://default:password@host:port

# ===========================================
# Django Settings
# ===========================================
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-openssl
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ===========================================
# JWT Settings
# ===========================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ===========================================
# Stripe
# ===========================================
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# AWS S3 / Cloudflare R2 (Media Storage)
# ===========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=wela-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=cdn.welamealprep.ca

# ===========================================
# Email (Postmark)
# ===========================================
POSTMARK_SERVER_TOKEN=
DEFAULT_FROM_EMAIL=hello@welamealprep.ca
ADMIN_EMAIL=admin@welamealprep.ca
EMAIL_ENABLED=True

# ===========================================
# Sentry (Error Monitoring)
# ===========================================
SENTRY_DSN=

# ===========================================
# Next.js Frontend
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ===========================================
# Canadian Tax
# ===========================================
HST_RATE=0.13
GST_HST_REGISTRATION_NUMBER=

# ===========================================
# Deployment Notes
# ===========================================
# Railway (Backend):
#   - Set DATABASE_URL, REDIS_URL from Railway provisions
#   - Set DJANGO_DEBUG=False
#   - Set DJANGO_ALLOWED_HOSTS=your-backend.railway.app
#   - Set DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
#   - Set CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-backend.railway.app
#   - Set FRONTEND_URL=https://your-frontend.vercel.app
#   - Generate a strong DJANGO_SECRET_KEY with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# Vercel (Frontend):
#   - Set NEXT_PUBLIC_API_URL=https://your-backend.railway.app/api/v1
#   - Set NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY to your live Stripe key
#   - Set NEXT_PUBLIC_SITE_URL=https://your-frontend.vercel.app
